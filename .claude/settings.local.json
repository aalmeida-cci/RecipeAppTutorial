{
  "permissions": {
    "allow": [
      "Bash(cat /tmp/android-res/commonMain/org/jetbrains/compose/resources/ResourceEnvironment.kt)",
      "Read(//private/tmp/android-res/commonMain/org/jetbrains/compose/resources/**)",
      "WebFetch(domain:medium.com)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./.claude/hooks/pre-commit.sh",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
